<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Does this app track users across other apps/websites? No. -->
	<key>NSPrivacyTracking</key>
	<false/>

	<!-- Domains used for tracking. None. -->
	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<!-- No personal data is collected. -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>

	<!-- Required-reason APIs used by Flutter / Hive / path_provider. -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<!-- NSUserDefaults — used by Hive (hive_flutter) for data storage.
		     Reason CA92.1: App functionality (data stored for app to function). -->
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
		<!-- File timestamp APIs — used by path_provider / Flutter engine.
		     Reason C617.1: Inside app or group container. -->
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>C617.1</string>
			</array>
		</dict>
		<!-- System boot time — used by Flutter engine internals.
		     Reason 35F9.1: Measure time on device (no server transmission). -->
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategorySystemBootTime</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>35F9.1</string>
			</array>
		</dict>
		<!-- Disk space — used by Flutter engine.
		     Reason E174.1: Write or delete file on behalf of the user. -->
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryDiskSpace</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>E174.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
